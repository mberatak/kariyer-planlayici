# Environment Variables

# PostgreSQL (isteğe bağlı - statik veri varsayılan olarak çalışır)
DATABASE_URL=postgresql://user:password@localhost:5432/kariyer_db

# Authentication (isteğe bağlı)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Analytics (isteğe bağlı)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking (isteğe bağlı)
SENTRY_DSN=
